{
	"name": "svelte-global-typescript",
	"version": "1.0.0",
	"description": "Enable TypeScript mode by default in Svelte components.",
	"license": "BSD-3-Clause",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/usebarekey/svelte-global-typescript.git"
	},
	"files": [
		".dist",
		"README.md"
	],
	"type": "module",
	"exports": {
		".": {
			"types": "./.dist/mod.d.mts",
			"default": "./.dist/mod.mjs"
		},
		"./vite": {
			"types": "./.dist/vite.d.mts",
			"default": "./.dist/vite.mjs"
		}
	},
	"scripts": {
		"build": "vp pack",
		"check": "vp check",
		"fmt": "vp fmt . --write",
		"lint": "vp lint",
		"test": "vp pack && vp test run"
	},
	"dependencies": {
		"magic-string": "^0.30.21"
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.0",
		"@sveltejs/kit": "^2.0.0",
		"@types/node": "^26.1.0",
		"svelte": "^5.0.0",
		"typescript": "^6.0.0",
		"vite": "catalog:",
		"vitest": "^4.1.9"
	},
	"peerDependencies": {
		"svelte": "^5.0.0",
		"vite": "^7.0.0 || ^8.0.0"
	},
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "11.10.0",
			"onFail": "download"
		}
	},
	"engines": {
		"node": "^22.12.0 || >=24.0.0"
	},
	"packageManager": "pnpm@11.10.0"
}
